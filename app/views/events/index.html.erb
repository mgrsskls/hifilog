<% content_for :header do %>
  <div class="Heading">
    <h1>Hi-Fi Events &amp; Shows</h1>
  </div>

  <nav aria-label="<%= Event.model_name.human.pluralize %>">
    <ul class="Tabs">
      <li>
        <%= link_to "Upcoming <span>(#{@all_upcoming_events_count})</span>".html_safe, events_path, "aria-current": @active_events == :upcoming %>
      </li>
      <li>
        <%= link_to "Past <span>(#{@all_past_events_count})</span>".html_safe, past_events_path, "aria-current": @active_events == :past %>
      </li>
    </ul>
  </nav>

  <div class="u-flex u-spaceBetween u-gap-md u-flexWrap">
    <% filtered_country_name = country_name_from_country_code(params[:country]) if params[:country].present? %>
    <% temp = @active_events == :upcoming ? 'upcoming' : 'past' %>
    <p class="u-mb-0 u-flex u-alignCenter">
      <small>
        <% if filtered_country_name.present? && @selected_year.present? %>
          <%= "#{@events.size} #{temp} events in #{filtered_country_name} in #{@selected_year}." %>
        <% elsif filtered_country_name.present? %>
          <%= "#{@events.size} #{temp} events in #{filtered_country_name}." %>
        <% elsif @selected_year.present? %>
          <%= "#{@events.size} #{temp} events in #{@selected_year}." %>
        <% else %>
          <%= "#{@events.size} #{temp} events worldwide." %>
        <% end %>
      </small>
    </p>

    <form class="u-flex u-gap-md u-alignCenter u-flexWrap">
      <% if @active_events == :past %>
        <div class="u-flex u-gap-md u-alignCenter">
          <label for="events-year-filter">Year</label>
          <select name="year" id="events-year-filter" class="events-filter">
            <% @available_years.each do |year| %>
              <option value="<%= year %>"<%= " selected" if year.to_s == @selected_year.to_s %>>
                <%= year %>
              </option>
            <% end %>
          </select>
        </div>
      <% end %>
      <div class="u-flex u-gap-md u-alignCenter">
        <label for="events-country-filter">Countries</label>
        <%= country_select(nil,
          "country",
          {
          only: @country_codes,
            include_blank: "All",
            selected: params[:country]&.upcase
          },
          {
            id: "events-country-filter",
            class: "events-filter"
          })
        %>
      </div>
    </form>
  </div>
<% end %>

<%= render "shared/events",
  events: @events,
  empty_state_message: t('event_attendee.empty_states.index'),
  after_create_redirect: @after_create_redirect,
  after_destroy_redirect: @after_destroy_redirect,
  years: @years,
  active_events: @active_events,
  event_bookmarks: @event_bookmarks
%>
