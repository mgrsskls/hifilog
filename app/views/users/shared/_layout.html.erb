<% categories ||= [] %>
<% render_headline ||= false %>

<% content_for :preloading do %>
  <% if user.decorative_image.attached? %>
    <link rel="preload" href="<%= cdn_image_url(user.decorative_image.variant(:large)) %>" as="image" type="image/webp">
  <% end %>
  <% if user.avatar.attached? && current_user != user %>
    <link rel="preload" href="<%= cdn_image_url(user.avatar.variant(:thumb)) %>" as="image" type="image/webp">
  <% end %>
<% end %>

<% content_for :css do %>
  <%= stylesheet_link_tag "profile" %>
<% end %>

<% if user.hidden? %>
  <p class="FlashMessage FlashMessage--alert">
    Your profile is not visible to other users. You can change this in your <%= link_to "account settings", edit_user_registration_path %>.
  </p>
<% end %>

<div class="Profile">
  <div class="Profile-header">
    <% if user.decorative_image.attached? %>
      <picture>
        <%= image_tag cdn_image_url(user.decorative_image.variant(:large)), "aria-hidden": "true", alt: "", class: "Profile-headerImage", width: 1512, height: 314, "fetchpriority": "high" %>
      </picture>
    <% end %>
  </div>
  <div class="Profile-content u-container" id="products">
    <div class="Profile-meta">
      <div class="Sidebar">
        <div class="Sidebar-header">
          <figure class="Sidebar-userName">
            <%= render "shared/avatar", user: user, size: 48 %>
            <figcaption class="is-dark">
              <h1><%= user.user_name %></h1>
              <small>
                <b>Member since</b> <time datetime="<%= format_iso_datetime user.created_at %>" title="<%= user.created_at.strftime("%B %d, %Y") %>"><%= format_date(user.created_at).html_safe %></time>
              </small>
            </figcaption>
          </figure>
          <button class="Sidebar-toggle" aria-expanded="false">
            Menu
            <svg aria-label="Open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" width="24" height="24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg aria-label="Close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" width="24" height="24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav>
          <ul class="Sidebar-menu" id="sidebar-menu">
            <li>
              <%= link_to 'Overview', user.profile_path, "aria-current": request.path == user.profile_path ? "page" : "false", class: "Sidebar-link" %>
            </li>
            <li>
              <span>
                <%= link_to t('headings.current_products'), user.collection_path, "aria-current": request.path == user.collection_path ? "page" : "false", class: "Sidebar-link" %>
                <small><%= user_possessions_count(user: user) %></small>
              </span>
              <% setups = user.setups.where(private: false) %>
              <% if setups.any? %>
                <ul>
                  <% setups.each do |setup| %>
                    <li>
                      <%= link_to setup.name, user_setup_path(user_id: user.lowercase_user_name, setup: setup.friendly_id), "aria-current": request.path == user_setup_path(user_id: user.lowercase_user_name, setup: setup.friendly_id) ? "page" : "false", class: "Sidebar-link" %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </li>
            <li>
              <span>
                <%= link_to t('headings.prev_owneds'), user_previous_products_path(user_id: user.lowercase_user_name), "aria-current": request.path == user_previous_products_path(user_id: user.lowercase_user_name) ? "page" : "false", class: "Sidebar-link" %>
                <small><%= user_possessions_count(user: user, prev_owned: true) %></small>
              </span>
            </li>
            <li>
              <%= link_to t('headings.history'), user_history_path(user_id: user.lowercase_user_name), "aria-current": request.path == user_history_path(user_id: user.lowercase_user_name) ? "page" : "false", class: "Sidebar-link" %>
            </li>
            <li class="Sidebar-separator">
              <%= link_to t('headings.contributions'), user_contributions_path(user_id: user.lowercase_user_name), "aria-current": request.path == user_contributions_path(user_id: user.lowercase_user_name) ? "page" : "false", class: "Sidebar-link" %>
            </li>
          </ul>
        </nav>
      </div>
    </div>
    <div class="Profile-products">
      <% if render_headline %>
        <div class="Heading">
          <h2><%= heading %></h2>
          <% if defined?(categories) && defined?(sub_category) %>
            <%= render "shared/category_filter", categories: categories, sub_category: sub_category %>
          <% end %>
        </div>
      <% end %>

      <div class="Profile-main">
        <%= yield %>
      </div>

    </div>
  </div>
</div>
